# Copy this file to .env.local for local work, then run: direnv allow
# Keep real values in .env.local or Fly secrets. Do not commit them.

export DATABASE_URL=ecto://postgres:postgres@localhost/siwa_server_dev
export SECRET_KEY_BASE=
export PHX_HOST=127.0.0.1
export PORT=4100

# Shared SIWA receipt signing
export SIWA_RECEIPT_SECRET=
export SIWA_NONCE_TTL_SECONDS=300
export SIWA_RECEIPT_TTL_SECONDS=3600
export SIWA_HTTP_SIGNATURE_TOLERANCE_SECONDS=300

# Replay cleanup
export SIWA_CLEANUP_ENABLED=true
export SIWA_CLEANUP_INTERVAL_MS=60000
export SIWA_CLEANUP_BATCH_SIZE=1000

# Base mainnet RPC for Agent account owner checks
export BASE_RPC_URL=

# Internal keyring
export KEYSTORE_PASSWORD=
export KEYRING_PROXY_SECRET=
